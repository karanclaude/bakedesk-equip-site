        <tr><td>Large Production</td><td>300–1,000 kg</td><td>232–600 sq m (2,500–6,500 sq ft)</td><td>10–25</td><td>₹60L – ₹2 crore</td></tr>
        <tr><td>Industrial</td><td>1,000 kg+</td><td>600+ sq m (6,500+ sq ft)</td><td>25+</td><td>₹2 crore+</td></tr>
