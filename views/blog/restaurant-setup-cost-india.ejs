        <tr><td><strong>Trade License</strong></td><td>Municipal Corporation</td><td>₹5,000 – ₹25,000/year</td><td>15–45 days</td><td>Mandatory for any commercial establishment</td></tr>
        <tr><td><strong>Eating House License</strong></td><td>Local Police / Municipal Authority</td><td>₹3,000 – ₹15,000</td><td>15–30 days</td><td>Required in most states for restaurants open after 11pm</td></tr>
        <tr><td><strong>Fire NOC</strong></td><td>State Fire Department</td><td>₹10,000 – ₹50,000</td><td>30–90 days</td><td>Mandatory above certain sq ft; requires fire safety equipment</td></tr>
        <tr><td><strong>GST Registration</strong></td><td>GST Council / GSTIN portal</td><td>Free (government fee); ₹2,000–₹5,000 (CA fees)</td><td>3–7 days</td><td>Mandatory for annual turnover above ₹20L; restaurant GST rate 5%</td></tr>
