        <tr><th>OTG Size</th><th>Trays</th><th>What You Can Bake Per Batch</th><th>Best For</th><th>Price Range</th></tr>
      </thead>
      <tbody>
        <tr><td>25–30 litres</td><td>1–2</td><td>12 muffins or 1 × 8" cake or 12 cookies</td><td>Starting out, testing recipes</td><td>₹4,000 – ₹8,000</td></tr>
        <tr><td>35–40 litres</td><td>2</td><td>24 muffins or 2 × 8" cakes or 24 cookies</td><td>Small orders, 20–30 pieces/day</td><td>₹8,000 – ₹14,000</td></tr>
        <tr><td>45–60 litres</td><td>2–3</td><td>36 muffins or 3 × 8" cakes or 36 cookies</td><td>Regular orders, 50–80 pieces/day</td><td>₹12,000 – ₹22,000</td></tr>
        <tr><td>60+ litres</td><td>3–4</td><td>48+ pieces; closer to small commercial</td><td>High volume home baking</td><td>₹18,000 – ₹35,000</td></tr>
