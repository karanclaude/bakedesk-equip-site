        <tr><td>Home Bakery (order-based)</td><td>₹20,000 – ₹80,000</td><td>₹30,000 – ₹2,00,000</td><td>1–4 months</td></tr>
        <tr><td>Cloud Kitchen / Ghost Bakery</td><td>₹1,50,000 – ₹5,00,000</td><td>₹1,00,000 – ₹5,00,000</td><td>4–9 months</td></tr>
        <tr><td>Small Retail Bakery</td><td>₹5,00,000 – ₹12,00,000</td><td>₹2,00,000 – ₹8,00,000</td><td>8–18 months</td></tr>
        <tr><td>Medium Retail Bakery</td><td>₹12,00,000 – ₹25,00,000</td><td>₹5,00,000 – ₹20,00,000</td><td>12–24 months</td></tr>
