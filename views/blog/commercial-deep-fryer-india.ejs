      </thead>
      <tbody>
        <tr><td>5–8L</td><td>1–3 kg/hour</td><td>Home-style shops, small bakeries, supplementary frying</td></tr>
        <tr><td>10–15L</td><td>4–8 kg/hour</td><td>Small restaurants, cafes, food trucks</td></tr>
        <tr><td>18–25L</td><td>10–20 kg/hour</td><td>Mid-volume restaurants, dhabas, catering</td></tr>
        <tr><td>30–40L</td><td>20–35 kg/hour</td><td>QSR outlets, cloud kitchens, hotel banquet kitchens</td></tr>
