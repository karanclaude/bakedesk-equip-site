        <tr><td>Temperature Range</td><td>50°C – 300°C</td><td>30°C – 300°C</td></tr>
        <tr><td>Humidity Control</td><td>None (some have basic steam injection)</td><td>Precise 0%–100% humidity control</td></tr>
        <tr><td>Steam Capability</td><td>None or limited</td><td>Full steam mode (replaces a steamer)</td></tr>
